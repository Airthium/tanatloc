{
  "name": "tanatloc",
  "version": "1.4.0",
  "description": "Tanatloc",
  "homepage": "./",
  "repository": "git@github.com:Airthium/tanatloc.git",
  "license": "AGPL-3.0-or-later",
  "author": {
    "name": "Airthium",
    "url": "https://github.com/orgs/Airthium/people"
  },
  "type": "module",
  "main": "package.json",
  "scripts": {
    "depcheck": "node config/depcheck/depcheckrc.js",
    "prettier": "prettier -l '**/*.{js,jsx,ts,tsx,json,md,css}'",
    "prettier:write": "prettier --write '**/*.{js,jsx,ts,tsx,json,md,css}'",
    "lint": "eslint --quiet",
    "doc": "typedoc --options config/typedoc/config.json",
    "testwatch": "jest --config config/jest/jest.config.js --watch",
    "test": "jest --config config/jest/jest.config.js --coverage --silent --runInBand",
    "speedtest": "jest --config config/jest/jest.config.js --silent --runInBand",
    "sonar": ".github/workflows/sonar.local.sh",
    "prestart": "yarn prestart:config && yarn prestart:database && yarn prestart:init && yarn prestart:package && yarn prestart:install && yarn prestart:run",
    "prestart:config": "swc config/db.ts --out-dir dist-install && swc config/storage.ts --out-dir dist-install",
    "prestart:database": "swc src/database/index.ts --out-dir dist-install",
    "prestart:init": "swc src/server/init/database.ts --out-dir dist-install",
    "prestart:package": "swc package.json --out-dir dist-install --copy-files",
    "prestart:install": "swc install --out-dir dist-install",
    "prestart:run": "node --import tsx dist-install/install/index.js",
    "prestart:norun": "yarn prestart:config && yarn prestart:database && yarn prestart:init && yarn prestart:package && yarn prestart:install",
    "dev": "NODE_OPTIONS=\"--max_old_space_size=8192\" NEXT_PUBLIC_SOURCE_BRANCH=$(git rev-parse --abbrev-ref HEAD) NEXT_PUBLIC_SOURCE_COMMIT=$(git rev-parse --short HEAD) nodemon",
    "build": "yarn build:server && yarn build:client",
    "build:server": "yarn build:server:config && yarn build:server:src && yarn build:server:models && yarn build:server:plugins && yarn build:server:postprocessing && yarn build:server:templates",
    "build:server:config": "swc config --out-dir dist",
    "build:server:src": "swc src --out-dir dist",
    "build:server:models": "swc models --out-dir dist",
    "build:server:plugins": "swc plugins --out-dir dist --copy-files",
    "build:server:postprocessing": "swc postprocessing --out-dir dist --copy-files",
    "build:server:templates": "swc templates --out-dir dist --copy-files",
    "build:client": "NEXT_PUBLIC_SOURCE_BRANCH=$(git rev-parse --abbrev-ref HEAD) NEXT_PUBLIC_SOURCE_COMMIT=$(git rev-parse --short HEAD) next build",
    "sitemap": "next-sitemap --config config/sitemap/sitemap.config.mjs",
    "start": "NODE_ENV=production NODE_OPTIONS=\"--max_old_space_size=8192\" node --import tsx dist/src/server/index.js",
    "workflow": ".github/workflows/node.local.sh",
    "modelValidator": "ts-json-schema-generator --path models/index.d.ts --type 'IModel' --tsconfig ./tsconfig.json --no-type-check --out src/components/editor/steps/model.json"
  },
  "dependencies": {
    "electron": "41.3.0",
    "electron-serve": "3.0.1",
    "electron-store": "11.0.2"
  },
  "devDependencies": {
    "@2ltech/deep-object-diff": "1.1.7",
    "@2ltech/extract-json-from-string": "1.0.6",
    "@2ltech/pg-format": "1.0.8",
    "@airthium/tanatloc-3d": "1.2.36",
    "@airthium/tanatloc-formula-validator": "1.0.72",
    "@ant-design/icons": "6.2.2",
    "@babel/core": "7.29.0",
    "@babel/plugin-syntax-import-assertions": "7.28.6",
    "@babel/preset-env": "7.29.2",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@hapi/iron": "7.0.1",
    "@sentry/nextjs": "10.50.0",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.32",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/archiver": "7.0.0",
    "@types/babel__preset-env": "7.10.0",
    "@types/cookie": "1.0.0",
    "@types/ejs": "3.1.5",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.24",
    "@types/node": "25.6.0",
    "@types/passport": "1.0.17",
    "@types/passport-local": "1.0.38",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/set-interval-async": "3.0.1",
    "@types/sharp": "0.32.0",
    "@types/tar": "7.0.87",
    "@types/url-join": "5.0.0",
    "@types/uuid": "11.0.0",
    "ajv": "8.20.0",
    "antd": "5.29.3",
    "archiver": "7.0.1",
    "babel-jest": "30.3.0",
    "cookie": "1.1.1",
    "depcheck": "1.4.7",
    "ejs": "5.0.2",
    "email-addresses": "5.0.0",
    "eslint": "10.2.1",
    "eslint-config-next": "16.2.4",
    "express": "5.2.1",
    "form-data": "4.0.5",
    "html-react-parser": "6.0.1",
    "https-proxy-agent": "9.0.0",
    "identity-obj-proxy": "3.0.0",
    "ignore-loader": "0.1.2",
    "is-docker": "4.0.0",
    "is-electron": "2.2.2",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "json5": "2.2.3",
    "lodash": "4.18.1",
    "mailersend": "2.8.0",
    "mathjax": "4.1.1",
    "next": "15.5.15",
    "next-sitemap": "4.2.3",
    "node-fetch": "3.3.2",
    "nodemon": "3.1.14",
    "passport": "0.7.0",
    "passport-local": "1.0.0",
    "pg": "8.20.0",
    "pg-native": "npm:@airthium/pg-native@3.0.2",
    "prettier": "3.8.3",
    "react": "19.2.5",
    "react-ace": "14.0.1",
    "react-cookie": "8.1.0",
    "react-dom": "19.2.5",
    "recharts": "3.8.1",
    "set-interval-async": "3.0.3",
    "sharp": "0.34.5",
    "swr": "2.4.1",
    "tar": "7.5.13",
    "ts-json-schema-generator": "2.9.0",
    "tsx": "4.21.0",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "url-join": "5.0.0",
    "uuid": "14.0.0"
  },
  "packageManager": "yarn@4.9.1"
}
